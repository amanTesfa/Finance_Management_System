@{
    ViewData["Title"] = "Login";
    Layout = null;
}
@model Finance_Management_System.Models.LoginUI

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Finance Management System</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">
</head>
<body>

    <style>
        .login-page {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(rgba(255,255,255,0.85), rgba(255,255,255,0.85)), url('https://plus.unsplash.com/premium_photo-1681487769650-a0c3fbaed85a?q=80&w=1555&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D') center/cover no-repeat; padding: 40px 0;
        }

        .login-card {
            width: 420px;
            padding: 48px 40px;
            border-radius: 8px;
            background: linear-gradient(180deg, #6e63ff 0%, #9b2cf8 60%, #c81bd8 100%);
            color: #fff;
            box-shadow: 0 8px 30px rgba(15, 15, 15, 0.2);
            text-align: center;
        }

        .login-logo {
            width: 92px;
            height: 92px;
            margin: 0 auto 16px;
            border-radius: 50%;
            background: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
        }

            .login-logo svg {
                width: 48px;
                height: 48px;
                fill: #333;
            }

        .login-title {
            font-weight: 600;
            letter-spacing: 2px;
            margin-bottom: 28px;
            font-size: 22px;
        }

        .input-group {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 20px;
            padding-bottom: 6px;
        }

        .input-group-credentials {
            border-bottom: 1px solid rgba(255,255,255,0.25);
        }

        .input-group-text, .input-group-check {
            display: flex;
            align-items: center;
            justify-content: center;
            min-width: 38px;
            height: 34px;
            padding: 0;
            margin: 0;
            background: transparent;
            color: rgba(255,255,255,0.9);
            border: none;
        }

            .input-group-text svg {
                display: block;
            }

        .form-control-input {
            flex: 1 1 auto;
            min-width: 0;
            background: transparent;
            border: none;
            border-radius: 0;
            color: #fff;
            padding: 8px 0;
            font-size: 14px;
            outline: none;
        }

            .form-control-input::placeholder {
                color: rgba(255,255,255,0.75);
            }

            .form-control-input:focus {
                box-shadow: none;
            }

        .remember-row {
            display: flex;
            align-items: center;
            gap: 8px;
            justify-content: flex-start;
            margin-bottom: 22px;
        }

        .btn-login {
            background: #fff;
            color: #4b197f;
            border-radius: 28px;
            padding: 8px 28px;
            font-weight: 600;
            border: none;
            box-shadow: 0 6px 14px rgba(75,25,127,0.15);
        }

            .btn-login:hover {
                background: linear-gradient(180deg, #6e63ff 0%, #9b2cf8 60%, #c81bd8 100%);
                color: #fff;
            }

        .forgot-link {
            display: block;
            margin-top: 26px;
            color: rgba(255,255,255,0.85);
            font-size: 13px;
            text-decoration: none;
        }


        .input-group-credentials {
            position: relative;
            overflow: hidden;
            transition: border-color 0.28s ease;
        }

            .input-group-credentials::after {
                content: "";
                position: absolute;
                left: 0;
                bottom: 0;
                height: 3px;
                width: 0;
                background: #ffffff;
                transform-origin: left center;
                transition: width 320ms cubic-bezier(.2, .9, .2, 1);
                pointer-events: none;
            }

            .input-group-credentials:focus-within::after {
                width: 100%;
            }

            .input-group-credentials:focus-within {
                border-bottom-color: #ffffff;
            }

                .input-group-credentials:focus-within .input-group-text {
                    color: #ffffff;
                }
    </style>
<div class="login-page">
    <div class="login-card">
        <div class="login-logo" aria-hidden="true">
            <svg viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="logo">
                <path d="M8 52h48L42 18 32 34 22 22z"></path>
            </svg>
        </div>

        <div class="login-title">LOG IN</div>

        <form asp-controller="Login" asp-action="Index" method="post" class="text-start">
            @Html.AntiForgeryToken()

            <div class="input-group input-group-credentials">
                <span class="input-group-text" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        <path d="M12 12c2.7 0 5-2.3 5-5s-2.3-5-5-5-5 2.3-5 5 2.3 5 5 5zm0 2c-3.3 0-10 1.7-10 5v2h20v-2c0-3.3-6.7-5-10-5z" />
                    </svg>
                </span>
                <input asp-for="Username" class="form-control-input" placeholder="Username" />
            </div>

            <div class="input-group input-group-credentials">
                <span class="input-group-text" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        <path d="M17 8V7c0-2.8-2.2-5-5-5S7 4.2 7 7v1H5v14h14V8h-2zm-6 0V7c0-1.7 1.3-3 3-3s3 1.3 3 3v1H11z" />
                    </svg>
                </span>
                <input asp-for="Password" type="password" class="form-control-input" placeholder="Password" />
            </div>

            <div class="input-group">
                <span class="input-group-check" aria-hidden="true">
                    <input asp-for="RememberMe" type="checkbox" class="form-check-input" id="rememberMe" />
                </span>
                <label class="form-check-label form-control-input" for="rememberMe" style="color:rgba(255,255,255,0.95); margin-bottom:0;">Remember me</label>
            </div>

            <div class="d-flex justify-content-center">
                <button type="submit" class="btn btn-login">Login</button>
            </div>
        </form>

        <a class="forgot-link" href="#" aria-label="Forgot Password">Forgot Password?</a>
    </div>
</div> 
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-MrcW6ZMFYlzcLA8Nl+NtUVF0sA7MsXsP1UyJoMp4YLEuNSfAP+JcXn/tWtIaxVXM" crossorigin="anonymous"></script>
</body>